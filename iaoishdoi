local function isBP(n)
	return n == "Head" or n:find("Torso") or n:find("Leg") or n:find("Arm")
end

local function isCP(p)
	return p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" and p.Name ~= "GlowShell"
end

local function getBB(parts)
	local mn, mx
	for i = 1, #parts do
		local p = parts[i]
		if not p or not p.Parent then
			return nil, nil
		end
		local cf, sz = p.CFrame, p.Size
		if not cf or not sz then
			return nil, nil
		end
		mn = m3(mn or cf.Position, (cf - sz*0.5).Position)
		mx = m3x(mx or cf.Position, (cf + sz*0.5).Position)
	end
	if not mn or not mx then
		return nil, nil
	end
	local size = mx - mn
	if size.Magnitude > 500 or size.Magnitude < 0.1 then
		return nil, nil
	end
	local c = (mn + mx)*0.5
	local f = Vector3.new(c.X, c.Y, mx.Z)
	return CFrame.new(c, f), size
end

local function w2sc(w)
	local s, inB = w2s(cam, w)
	return Vector2.new(s.X, s.Y), inB, s.Z
end

local function calcCorn(cf, sz)
	if not cf or not sz then
		return {
			corners = {},
			tl = Vector2.new(0, 0),
			tr = Vector2.new(0, 0),
			bl = Vector2.new(0, 0),
			br = Vector2.new(0, 0)
		}
	end
	local corn = cr(#VERTS)
	for i = 1, #VERTS do
		corn[i] = w2sc((cf + sz*0.5*VERTS[i]).Position)
	end
	local mn = m2(vs, up(corn))
	local mx = m2x(Vector2.zero, up(corn))
	
	if (mx - mn).Magnitude > 5000 then
		return {
			corners = {},
			tl = Vector2.new(0, 0),
			tr = Vector2.new(0, 0),
			bl = Vector2.new(0, 0),
			br = Vector2.new(0, 0)
		}
	end
	
	return {
		corners = corn,
		tl = Vector2.new(fl(mn.X), fl(mn.Y)),
		tr = Vector2.new(fl(mx.X), fl(mn.Y)),
		bl = Vector2.new(fl(mn.X), fl(mx.Y)),
		br = Vector2.new(fl(mx.X), fl(mx.Y))
	}
end

local function calcCornViewport(cf, sz, vpCam, vpFrame)
	if not cf or not sz then
		return {
			corners = {},
			tl = Vector2.new(0, 0),
			tr = Vector2.new(0, 0),
			bl = Vector2.new(0, 0),
			br = Vector2.new(0, 0)
		}
	end
	
	local hrp = cf.Position
	local distance = (vpCam.CFrame.Position - hrp).Magnitude
	
	local vpfSize = vpFrame.AbsoluteSize
	local vpfPos = vpFrame.AbsolutePosition
	
	if vpfSize.X <= 0 or vpfSize.Y <= 0 then
		return {
			corners = {},
			tl = Vector2.new(0, 0),
			tr = Vector2.new(0, 0),
			bl = Vector2.new(0, 0),
			br = Vector2.new(0, 0)
		}
	end
	
	local fov = vpCam.FieldOfView or 70
	local num = math.tan(math.rad(fov / 2))
	local factorY = vpfSize.Y / (2 * distance * num)
	local factorX = vpfSize.X / (2 * distance * num * (vpfSize.X / vpfSize.Y))
	
	local boxHeight = sz.Y * factorY * 1.15
	local boxWidth = sz.X * factorX
	
	if boxHeight > 5000 or boxWidth > 5000 or boxHeight < 1 or boxWidth < 1 then
		return {
			corners = {},
			tl = Vector2.new(0, 0),
			tr = Vector2.new(0, 0),
			bl = Vector2.new(0, 0),
			br = Vector2.new(0, 0)
		}
	end
	
	local guiInset = guiService:GetGuiInset()
	local offsetY = guiInset.Y
	
	local centerX = vpfPos.X + (vpfSize.X / 2)
	local centerY = vpfPos.Y + (vpfSize.Y / 2)
	
	local minX = centerX - (boxWidth / 2)
	local minY = centerY - (boxHeight / 2) + offsetY
	local maxX = centerX + (boxWidth / 2)
	local maxY = centerY + (boxHeight / 2) + offsetY
	
	return {
		corners = {
			Vector2.new(minX, minY), Vector2.new(maxX, minY),
			Vector2.new(maxX, maxY), Vector2.new(minX, maxY),
			Vector2.new(minX, minY), Vector2.new(maxX, minY),
			Vector2.new(maxX, maxY), Vector2.new(minX, maxY)
		},
		tl = Vector2.new(fl(minX), fl(minY)),
		tr = Vector2.new(fl(maxX), fl(minY)),
		bl = Vector2.new(fl(minX), fl(maxY)),
		br = Vector2.new(fl(maxX), fl(maxY))
	}
end

local function rotV(v, rad)
	local x, y = v.X, v.Y
	local c, s = cs(rad), sn(rad)
	return Vector2.new(x*c - y*s, x*s + y*c)
end

local function parseC(self, col, out)
	if col == "Team Color" or (self.itf.shSet.useTeam and not out) then
		return self.itf.getTC(self.plr) or Color3.new(1,1,1)
	end
	return col
end

local function roleKey(self)
	local role = self.itf.roles[self.plr.Name]
	if role == "Murderer" then return "Mur" end
	if role == "Sheriff" or role == "Hero" then return "Shf" end
	return "Inno"
end

local ck = os.clock

local function gradS(c1, c2, p, off)
	return lc(c1, c2, sn(p*3.1416 + ck()*2 + (off or 0)*6.283)*0.5 + 0.5)
end

