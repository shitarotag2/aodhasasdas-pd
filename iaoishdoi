function Esp:Dest()
	for _, conn in pairs(self.charConns) do
		pcall(function() conn:Disconnect() end)
	end
	cl(self.charConns)
	for i = 1, #self.bin do
		self.bin[i]:Remove()
	end
	if self.av then self.av:Destroy() end
	if self.gf then self.gf:Destroy() end
	if self.ob then self.ob:Destroy() end
	if self.obk then self.obk:Destroy() end
	cl(self)
end

function Esp:gradTxt(pool, text, cx, topY, sz, fnt, out, oc, tr, c1, c2, off)
	local n = #text
	local widths = self._gw or {}
	self._gw = widths
	local total = 0
	for i = 1, n do
		local o = pool[i]
		if not o then
			o = self:_c("Text", { Center = false, Visible = false })
			pool[i] = o
		end
		o.Size = sz
		o.Font = fnt
		o.Text = text:sub(i, i)
		widths[i] = o.TextBounds.X
		total = total + widths[i]
	end
	for i = n + 1, #pool do pool[i].Visible = false end
	local x = cx - total*0.5
	for i = 1, n do
		local o = pool[i]
		o.Color = gradS(c1, c2, n > 1 and (i-1)/(n-1) or 0, off)
		o.Transparency = tr
		o.Outline = out
		o.OutlineColor = oc
		o.Position = Vector2.new(x, topY)
		o.Visible = true
		x = x + widths[i]
	end
end

function Esp:hideGrad(pool)
	for i = 1, #pool do pool[i].Visible = false end
end

function Esp:drawSegs(segs, tr, oon, ocol, otr, osegs)
	osegs = osegs or segs
	if oon then
		for i = 1, #osegs do
			local s = osegs[i]
			local k = self.cnk[i]
			if not k then
				k = self:_c("Line", { Thickness = 3, ZIndex = 100, Visible = false })
				self.cnk[i] = k
			end
			k.From = s[1]
			k.To = s[2]
			k.Color = ocol
			k.Transparency = otr
			k.Visible = true
		end
	end
	for i = 1, #segs do
		local s = segs[i]
		local o = self.cn[i]
		if not o then
			o = self:_c("Line", { Thickness = 1, ZIndex = 101, Visible = false })
			self.cn[i] = o
		end
		o.From = s[1]
		o.To = s[2]
		o.Color = s[3]
		o.Transparency = tr
		o.Visible = true
	end
	for i = #segs + 1, #self.cn do self.cn[i].Visible = false end
	for i = (oon and #osegs or 0) + 1, #self.cnk do self.cnk[i].Visible = false end
end

function Esp:hideRects(pool)
	for i = 1, #pool do pool[i].Visible = false end
end

function Esp:rect(pool, i, pos, size, col, tr, z)
	if size.X <= 0 or size.Y <= 0 then
		return i
	end
	local o = pool[i]
	if not o then
		o = self:_c("Square", { Filled = true, Visible = false, ZIndex = z })
		pool[i] = o
	end
	o.Position = pos
	o.Size = size
	o.Color = col
	o.Transparency = tr
	pcall(function() o.ZIndex = z end)
	o.Visible = true
	return i + 1
end

function Esp:drawCorners(corn, c1, c2, grd, tr, ocol, oon, otr)
	local tl, tr2, bl, br = corn.tl, corn.tr, corn.bl, corn.br
	local x1, y1 = tl.X, tl.Y
	local x2, y2 = br.X - 1, br.Y - 1
	local W, H = x2 - x1 + 1, y2 - y1 + 1
	if W <= 0 or H <= 0 then
		self:hideRects(self.rs)
		self:hideRects(self.rso)
		return
	end
	local lx = fl(W * 0.25)
	local ly = fl(H * 0.25)
	if lx < 1 then lx = 1 end
	if ly < 1 then ly = 1 end
	local CH = y2 - y1
	if CH <= 0 then CH = 1 end
	local function col(y)
		return grd and lc(c1, c2, (y - y1)/CH) or c1
	end
	local idx = 1
	local oi = 1
	if oon then
		oi = self:rect(self.rso, oi, Vector2.new(x1 - 1, y1 - 1), Vector2.new(lx + 2, 3), ocol, otr, 100)
		oi = self:rect(self.rso, oi, Vector2.new(x2 - lx, y1 - 1), Vector2.new(lx + 2, 3), ocol, otr, 100)
		oi = self:rect(self.rso, oi, Vector2.new(x1 - 1, y2 - 1), Vector2.new(lx + 2, 3), ocol, otr, 100)
		oi = self:rect(self.rso, oi, Vector2.new(x2 - lx, y2 - 1), Vector2.new(lx + 2, 3), ocol, otr, 100)
		oi = self:rect(self.rso, oi, Vector2.new(x1 - 1, y1 - 1), Vector2.new(3, ly + 2), ocol, otr, 100)
		oi = self:rect(self.rso, oi, Vector2.new(x2 - 1, y1 - 1), Vector2.new(3, ly + 2), ocol, otr, 100)
		oi = self:rect(self.rso, oi, Vector2.new(x1 - 1, y2 - ly), Vector2.new(3, ly + 2), ocol, otr, 100)
		oi = self:rect(self.rso, oi, Vector2.new(x2 - 1, y2 - ly), Vector2.new(3, ly + 2), ocol, otr, 100)
	end
	idx = self:rect(self.rs, idx, Vector2.new(x1, y1), Vector2.new(lx, 1), col(y1), tr, 101)
	idx = self:rect(self.rs, idx, Vector2.new(x2 - lx + 1, y1), Vector2.new(lx, 1), col(y1), tr, 101)
	idx = self:rect(self.rs, idx, Vector2.new(x1, y2), Vector2.new(lx, 1), col(y2), tr, 101)
	idx = self:rect(self.rs, idx, Vector2.new(x2 - lx + 1, y2), Vector2.new(lx, 1), col(y2), tr, 101)
	local N = grd and math.min(6, ly) or 1
	for s = 1, N do
		local a1, a2 = fl(ly*(s-1)/N), fl(ly*s/N)
		if a2 <= a1 then a2 = a1 + 1 end
		local yt1, yt2 = y1 + a1, y1 + a2
		local yb1, yb2 = y2 - a2 + 1, y2 - a1 + 1
		idx = self:rect(self.rs, idx, Vector2.new(x1, yt1), Vector2.new(1, yt2 - yt1), col((yt1 + yt2)*0.5), tr, 101)
		idx = self:rect(self.rs, idx, Vector2.new(x2, yt1), Vector2.new(1, yt2 - yt1), col((yt1 + yt2)*0.5), tr, 101)
		idx = self:rect(self.rs, idx, Vector2.new(x1, yb1), Vector2.new(1, yb2 - yb1), col((yb1 + yb2)*0.5), tr, 101)
		idx = self:rect(self.rs, idx, Vector2.new(x2, yb1), Vector2.new(1, yb2 - yb1), col((yb1 + yb2)*0.5), tr, 101)
	end
	for n = idx, #self.rs do self.rs[n].Visible = false end
	for n = (oon and oi or 1), #self.rso do self.rso[n].Visible = false end
end

function Esp:drawGradBox(corn, c1, c2, tr, ocol, oon, otr)
	local tl, tr2, bl, br = corn.tl, corn.tr, corn.bl, corn.br
	local x1, y1 = tl.X, tl.Y
	local x2, y2 = br.X - 1, br.Y - 1
	local W, H = x2 - x1 + 1, y2 - y1 + 1
	if W <= 0 or H <= 0 then
		self:hideRects(self.rs)
		self:hideRects(self.rso)
		return
	end
	local N = math.min(24, H)
	local idx = 1
	idx = self:rect(self.rs, idx, Vector2.new(x1, y1), Vector2.new(W, 1), c1, tr, 101)
	idx = self:rect(self.rs, idx, Vector2.new(x1, y2), Vector2.new(W, 1), c2, tr, 101)
	for s = 1, N do
		local a1, a2 = fl(H*(s-1)/N), fl(H*s/N)
		if a2 <= a1 then a2 = a1 + 1 end
		local ya, yb = y1 + a1, y1 + a2
		local cm = lc(c1, c2, ((a1 + a2)*0.5)/H)
		idx = self:rect(self.rs, idx, Vector2.new(x1, ya), Vector2.new(1, yb - ya), cm, tr, 101)
		idx = self:rect(self.rs, idx, Vector2.new(x2, ya), Vector2.new(1, yb - ya), cm, tr, 101)
	end
	for n = idx, #self.rs do self.rs[n].Visible = false end
	self:hideRects(self.rso)
end

function Esp:gLine(pool, a, b, c1, c2, tr, thick)
	local N = 10
	for i = 1, N do
		local f1, f2 = (i-1)/N, i/N
		local o = pool[i]
		if not o then
			o = self:_c("Line", { Thickness = thick, Visible = false })
			pool[i] = o
		end
		o.From = l2(a, b, f1)
		o.To = l2(a, b, f2)
		o.Color = lc(c1, c2, (f1+f2)*0.5)
		o.Transparency = tr
		o.Visible = true
	end
	for i = N + 1, #pool do pool[i].Visible = false end
end
function Esp:Upd()
    local itf = self.itf
    self.opt = itf.tSet[itf.isFr(self.plr) and "fr" or "en"]
    if not self.plr or not self.plr.Parent then
        self.en = false
        self.char = nil
        self.onSc = false
        return
    end
    
    local newChar = itf.getChar(self.plr)
    if newChar ~= self.cacheChar then
        cl(self.charCache)
        self.cacheChar = newChar
        self.childCnt = 0
        self.lastCacheTime = 0
        self.bodyPartsHash = nil
        
        for _, conn in pairs(self.charConns) do
            pcall(function() conn:Disconnect() end)
        end
        cl(self.charConns)
        
        if newChar then
            local function invalidateCache()
                cl(self.charCache)
                self.childCnt = 0
                self.lastCacheTime = 0
                self.bodyPartsHash = nil
            end
            
            self.charConns[1] = newChar.ChildAdded:Connect(invalidateCache)
            self.charConns[2] = newChar.ChildRemoved:Connect(invalidateCache)
            
            local hum = newChar:FindFirstChildOfClass("Humanoid")
            if hum then
                self.charConns[3] = hum.Died:Connect(invalidateCache)
            end
        end
    end
    
    self.char = newChar
    self.hp, self.maxHp = itf.getHp(self.plr)
    self.arm = itf.getArm(self.plr)
    self.wep = itf.getWep(self.plr)
    local hasUserId = self.plr.UserId ~= nil
    if self.plr == lp and not self.itf.allowlocal then
        self.en = false
    else
        self.en = self.opt.en and self.char and hasUserId and not
            (#itf.wlist > 0 and not fd(itf.wlist, self.plr.UserId))
    end

    local hd = self.en and fc(self.char, "Head")
    if not hd or not hd.Parent then
        self.charCache = {}
        self.onSc = false
        return
    end

    local activeCam = cam
    local cloneInfo = itf._clones[self.plr]
    local viewport = cloneInfo and cloneInfo.viewport
    
    if viewport then
        if not getgenv().VISUALS_TAB_OPEN then
            self.onSc = false
            return
        end
        activeCam = viewport.CurrentCamera or cam
    end

    self.viewport = viewport
    self.activeCam = activeCam

    local _, onSc, dep = self.customW2s(hd.Position)
    self.onSc = onSc
    self.dis = dep

    if itf.shSet.limDis and dep > itf.shSet.maxDis then
        self.onSc = false
    end

    if self.onSc then
		self:updateSkel()
        local ch = self.charCache
        local kids = gc(self.char)
        local now = tick()
        self.lastCacheTime = self.lastCacheTime or 0
        
        local validParts = {}
        for i = 1, #kids do
            local p = kids[i]
            if isA(p, "BasePart") and isBP(p.Name) and p.Parent then
                validParts[#validParts + 1] = p
            end
        end
        
        local currentHash = #validParts
        for i = 1, #validParts do
            currentHash = currentHash + (validParts[i]:GetFullName():len() * i)
        end
        
        if not ch[1] or self.bodyPartsHash ~= currentHash or (now - self.lastCacheTime) > 0.5 then
            cl(ch)
            for i = 1, #validParts do
                ch[i] = validParts[i]
            end
            self.bodyPartsHash = currentHash
            self.lastCacheTime = now
        end
        
        if #ch == 0 then
            self.onSc = false
            return
        end
        
        local cf, sz = getBB(ch)
        if not cf or not sz then
            cl(self.charCache)
            self.bodyPartsHash = nil
            self.lastCacheTime = 0
            self.onSc = false
            return
        end
        
        if viewport then
            self.corn = calcCornViewport(cf, sz, activeCam, viewport)
        else
            self.corn = calcCorn(cf, sz)
        end
    elseif self.opt.offAr and not cloneInfo then
        local cf = activeCam.CFrame
        local flt = fm(cf.Position, cf.RightVector, Vector3.yAxis)
        local obj = pos(flt, hd.Position)
        self.dir = Vector2.new(obj.X, obj.Z).Unit
    end
end
function Esp:Ren()
	local onSc = self.onSc or false
	local en = self.en or false
	local v = self.draw.v
	local h = self.draw.h
	local b3d = self.draw.b3d
	local itf = self.itf
	local opt = self.opt
	local corn = self.corn

	local boxOn = en and onSc and opt.box
	local corner = opt.boxType == "Corners"
	local grd = opt.boxGrd
	if not boxOn then
		v.b.Visible = false
		v.bo.Visible = false
		self.ob.Visible = false
		self.obk.Visible = false
		self:hideGrad(self.cn)
		self:hideGrad(self.cnk)
		self:hideRects(self.rs)
		self:hideRects(self.rso)
	elseif corner then
		v.b.Visible = false
		v.bo.Visible = false
		self.ob.Visible = false
		self.obk.Visible = false
		self:hideGrad(self.cn)
		self:hideGrad(self.cnk)
		self:drawCorners(corn,
			grd and opt.boxGrdCol[1] or parseC(self, opt.boxCol[1]),
			opt.boxGrdCol[2], grd, opt.boxCol[2],
			parseC(self, opt.boxOCol[1], true), opt.boxO, opt.boxOCol[2])
	elseif grd then
		v.b.Visible = false
		self.ob.Visible = false
		self.obk.Visible = false
		self:hideGrad(self.cn)
		self:hideGrad(self.cnk)
		self:drawGradBox(corn,
			opt.boxGrdCol[1], opt.boxGrdCol[2], opt.boxCol[2],
			parseC(self, opt.boxOCol[1], true), opt.boxO, opt.boxOCol[2])
		v.bo.Visible = opt.boxO
		if v.bo.Visible then
			local bo = v.bo
			bo.Position = corn.tl
			bo.Size = corn.br - corn.tl
			bo.Color = parseC(self, opt.boxOCol[1], true)
			bo.Transparency = opt.boxOCol[2]
			pcall(function() bo.ZIndex = 100 end)
		end
	else
		self.ob.Visible = false
		self.obk.Visible = false
		self:hideGrad(self.cn)
		self:hideGrad(self.cnk)
		self:hideRects(self.rs)
		self:hideRects(self.rso)
		v.b.Visible = true
		local b = v.b
		b.Position = corn.tl
		b.Size = corn.br - corn.tl
		b.Color = parseC(self, opt.boxCol[1])
		b.Transparency = opt.boxCol[2]
		pcall(function() b.ZIndex = 101 end)
		v.bo.Visible = opt.boxO
		if v.bo.Visible then
			local bo = v.bo
			bo.Position = corn.tl
			bo.Size = corn.br - corn.tl
			bo.Color = parseC(self, opt.boxOCol[1], true)
			bo.Transparency = opt.boxOCol[2]
			pcall(function() bo.ZIndex = 100 end)
		end
	end

	local fillOn = boxOn and opt.boxF
	if fillOn and opt.boxFGrd then
		v.bf.Visible = false
		self.gf.Position = UDim2.fromOffset(corn.tl.X, corn.tl.Y)
		self.gf.Size = UDim2.fromOffset(corn.br.X - corn.tl.X, corn.br.Y - corn.tl.Y)
		self.gfg.Color = ColorSequence.new(opt.boxFGrdCol[1], opt.boxFGrdCol[2])
		self.gf.BackgroundTransparency = 1 - opt.boxFCol[2]
		self.gf.Visible = true
	else
		self.gf.Visible = false
		v.bf.Visible = fillOn
		if fillOn then
			local bf = v.bf
			bf.Position = corn.tl
			bf.Size = corn.br - corn.tl
			bf.Color = parseC(self, opt.boxFCol[1])
			bf.Transparency = opt.boxFCol[2]
		end
	end

	local hbOn = en and onSc and opt.hb
	v.hbo.Visible = hbOn and opt.hbo
	if hbOn then
		local fr = corn.tl - HB_OFF
		local to = corn.bl - HB_OFF
		local top = l2(to, fr, self.hp/self.maxHp)

		if opt.hbGrd then
			v.hb.Visible = false
			self:gLine(self.ghb, top, to, opt.hbGrdCol[1], opt.hbGrdCol[2], 1, 1)
		else
			self:hideGrad(self.ghb)
			v.hb.Visible = true
			local hb = v.hb
			hb.To = to
			hb.From = top
			hb.Color = lc(opt.dyCol, opt.hlCol, self.hp/self.maxHp)
		end

		local hbo = v.hbo
		hbo.To = to + HO_OFF
		hbo.From = fr - HO_OFF
		hbo.Color = parseC(self, opt.hboCol[1], true)
		hbo.Transparency = opt.hboCol[2]
	else
		v.hb.Visible = false
		self:hideGrad(self.ghb)
	end

	local htOn = en and onSc and opt.hb and opt.ht
	if htOn then
		local fr = corn.tl - HB_OFF
		local to = corn.bl - HB_OFF
		local ht = v.ht
		ht.Text = rd(self.hp) .. "hp"
		ht.Size = itf.shSet.tSz
		ht.Font = itf.shSet.tFnt
		ht.Outline = opt.htOut
		ht.OutlineColor = parseC(self, opt.htOCol, true)
		local anchor = l2(to, fr, self.hp/self.maxHp) - HT_OFF
		if opt.htGrd then
			ht.Visible = false
			self:gradTxt(self.gtH, ht.Text, anchor.X - ht.TextBounds.X*0.5, anchor.Y - ht.TextBounds.Y*0.5, itf.shSet.tSz, itf.shSet.tFnt, opt.htOut, parseC(self, opt.htOCol, true), opt.htCol[2], opt.htGrdCol[1], opt.htGrdCol[2], self.ph)
		else
			self:hideGrad(self.gtH)
			ht.Visible = true
			ht.Color = parseC(self, opt.htCol[1])
			ht.Transparency = opt.htCol[2]
			ht.Position = anchor - ht.TextBounds*0.5
		end
	else
		v.ht.Visible = false
		self:hideGrad(self.gtH)
	end

	v.ab.Visible = en and onSc and opt.ab
	v.abo.Visible = v.ab.Visible and opt.abo
	if v.ab.Visible then
		local fr = corn.tr + AB_OFF
		local to = corn.br + AB_OFF
		local maxArm = 200

		local ab = v.ab
		ab.To = to
		ab.From = l2(to, fr, self.arm/maxArm)
		ab.Color = opt.abCol[1]

		local abo = v.abo
		abo.To = to + AO_OFF
		abo.From = fr - AO_OFF
		abo.Color = parseC(self, opt.aboCol[1], true)
		abo.Transparency = opt.aboCol[2]
	end

	v.at.Visible = en and onSc and opt.at
	if v.at.Visible then
		local fr = corn.tr + AB_OFF
		local to = corn.br + AB_OFF
		local maxArm = 200

		local at = v.at
		at.Text = rd(self.arm) .. "ap"
		at.Size = itf.shSet.tSz
		at.Font = itf.shSet.tFnt
		at.Color = parseC(self, opt.atCol[1])
		at.Transparency = opt.atCol[2]
		at.Outline = opt.atOut
		at.OutlineColor = parseC(self, opt.atOCol, true)
		at.Position = l2(to, fr, self.arm/maxArm) - Vector2.new(0, at.TextBounds.Y * 0.5) + AT_OFF
	end

	local nameOn = en and onSc and opt.name
	if nameOn then
		local n = v.n
		n.Size = itf.shSet.tSz
		n.Font = itf.shSet.tFnt
		n.Outline = opt.nOut
		n.OutlineColor = parseC(self, opt.nOCol, true)
		n.Text = self.plr.DisplayName
		local cx = (corn.tl.X + corn.tr.X)*0.5
		local topY = (corn.tl.Y + corn.tr.Y)*0.5 - n.TextBounds.Y - N_OFF.Y
		if opt.nGrd then
			n.Visible = false
			self:gradTxt(self.gtN, n.Text, cx, topY, itf.shSet.tSz, itf.shSet.tFnt, opt.nOut, parseC(self, opt.nOCol, true), opt.nCol[2], opt.nGrdCol[1], opt.nGrdCol[2], self.ph)
		else
			self:hideGrad(self.gtN)
			n.Visible = true
			n.Color = parseC(self, opt.nCol[1])
			n.Transparency = opt.nCol[2]
			n.Position = Vector2.new(cx, topY)
		end
	else
		v.n.Visible = false
		self:hideGrad(self.gtN)
	end

	local avOn = en and onSc and opt.av and not itf._clones[self.plr]
	self.av.Visible = avOn
	if avOn then
		local as = itf.shSet.tSz + 6
		self.av.Size = UDim2.fromOffset(as, as)
		local uid = self.plr.UserId
		if self.avId ~= uid then
			self.avId = uid
			self.av.Image = "rbxthumb://type=AvatarHeadShot&id=" .. tostring(uid) .. "&w=48&h=48"
		end
		local cx = (corn.tl.X + corn.tr.X)*0.5
		local midY = (corn.tl.Y + corn.tr.Y)*0.5
		if opt.name then
			local nh = v.n.TextBounds.Y
			self.av.Position = UDim2.fromOffset(cx + v.n.TextBounds.X*0.5 + as*0.5 + 4, midY - nh*0.5 - N_OFF.Y)
		else
			self.av.Position = UDim2.fromOffset(cx, midY - as*0.5 - N_OFF.Y)
		end
	end

	local flagOff = 0
	local flagOn = en and onSc and itf.tSet.en.flag
	if flagOn then
		local role = itf.roles[self.plr.Name]
		if role == "Murderer" or role == "Sheriff" then
			local fl = v.fl
			local mur = role == "Murderer"
			fl.Size = itf.shSet.tSz
			fl.Font = itf.shSet.tFnt
			fl.Outline = true
			fl.OutlineColor = Color3.new()
			fl.Text = mur and "MURDERER" or "SHERIFF"
			local colT = mur and itf.tSet.en.flagMurCol or itf.tSet.en.flagShfCol
			local grd = mur and itf.tSet.en.flagMurGrd or itf.tSet.en.flagShfGrd
			local grdCol = mur and itf.tSet.en.flagMurGrdCol or itf.tSet.en.flagShfGrdCol
			local cx = (corn.bl.X + corn.br.X)*0.5
			local topY = (corn.bl.Y + corn.br.Y)*0.5 + D_OFF.Y
			if grd then
				fl.Visible = false
				self:gradTxt(self.gtF, fl.Text, cx, topY, itf.shSet.tSz, itf.shSet.tFnt, true, Color3.new(), colT[2], grdCol[1], grdCol[2], self.ph)
			else
				self:hideGrad(self.gtF)
				fl.Visible = true
				fl.Color = colT[1]
				fl.Transparency = colT[2]
				fl.Position = Vector2.new(cx, topY)
			end
			flagOff = fl.TextBounds.Y
		else
			v.fl.Visible = false
			self:hideGrad(self.gtF)
		end
	else
		v.fl.Visible = false
		self:hideGrad(self.gtF)
	end

	local distOn = en and onSc and self.dis and opt.dis
	if distOn then
		local d = v.d
		d.Text = rd(self.dis) .. " studs"
		d.Size = itf.shSet.tSz
		d.Font = itf.shSet.tFnt
		d.Outline = opt.dOut
		d.OutlineColor = parseC(self, opt.dOCol, true)
		local cx = (corn.bl.X + corn.br.X)*0.5
		local topY = (corn.bl.Y + corn.br.Y)*0.5 + D_OFF.Y + flagOff
		if opt.dGrd then
			d.Visible = false
			self:gradTxt(self.gtD, d.Text, cx, topY, itf.shSet.tSz, itf.shSet.tFnt, opt.dOut, parseC(self, opt.dOCol, true), opt.dCol[2], opt.dGrdCol[1], opt.dGrdCol[2], self.ph)
		else
			self:hideGrad(self.gtD)
			d.Visible = true
			d.Color = parseC(self, opt.dCol[1])
			d.Transparency = opt.dCol[2]
			d.Position = Vector2.new(cx, topY)
		end
	else
		v.d.Visible = false
		self:hideGrad(self.gtD)
	end

	v.w.Visible = en and onSc and opt.wep
	if v.w.Visible then
		local w = v.w
		w.Text = self.wep
		w.Size = itf.shSet.tSz
		w.Font = itf.shSet.tFnt
		w.Color = parseC(self, opt.wCol[1])
		w.Transparency = opt.wCol[2]
		w.Outline = opt.wOut
		w.OutlineColor = parseC(self, opt.wOCol, true)
		w.Position = (corn.bl + corn.br)*0.5 + (v.d.Visible and D_OFF + Vector2.yAxis*v.d.TextBounds.Y or Vector2.zero)
	end

	v.tr.Visible = en and onSc and opt.tr
	v.tro.Visible = v.tr.Visible and opt.tro
	if v.tr.Visible then
		local tr = v.tr
		tr.Color = parseC(self, opt.trCol[1])
		tr.Transparency = opt.trCol[2]
		tr.To = (corn.bl + corn.br)*0.5
		tr.From =
			opt.trOrg == "Middle" and vs*0.5 or
			opt.trOrg == "Top" and vs*Vector2.new(0.5, 0) or
			opt.trOrg == "Bottom" and vs*Vector2.new(0.5, 1)

		local tro = v.tro
		tro.Color = parseC(self, opt.troCol[1], true)
		tro.Transparency = opt.troCol[2]
		tro.To = tr.To
		tro.From = tr.From
	end

	h.ar.Visible = en and (not onSc) and opt.offAr
	h.aro.Visible = h.ar.Visible and opt.offArO
	if h.ar.Visible and self.dir then
		local ar = h.ar
		ar.PointA = m2(m2x(vs*0.5 + self.dir*opt.offArRad, Vector2.one*25), vs - Vector2.one*25)
		ar.PointB = ar.PointA - rotV(self.dir, 0.45)*opt.offArSz
		ar.PointC = ar.PointA - rotV(self.dir, -0.45)*opt.offArSz
		ar.Color = parseC(self, opt.offArCol[1])
		ar.Transparency = opt.offArCol[2]

		local aro = h.aro
		aro.PointA = ar.PointA
		aro.PointB = ar.PointB
		aro.PointC = ar.PointC
		aro.Color = parseC(self, opt.offArOCol[1], true)
		aro.Transparency = opt.offArOCol[2]
	end

	local b3dEn = en and onSc and opt.b3d
	for i = 1, #b3d do
		local f = b3d[i]
		for i2 = 1, #f do
			local ln = f[i2]
			ln.Visible = b3dEn
			ln.Color = parseC(self, opt.b3dCol[1])
			ln.Transparency = opt.b3dCol[2]
		end

		if b3dEn then
			local l1 = f[1]
			l1.From = corn.corners[i]
			l1.To = corn.corners[i == 4 and 1 or i+1]

			local l2 = f[2]
			l2.From = corn.corners[i == 4 and 1 or i+1]
			l2.To = corn.corners[i == 4 and 5 or i+5]

			local l3 = f[3]
			l3.From = corn.corners[i == 4 and 5 or i+5]
			l3.To = corn.corners[i == 4 and 8 or i+4]
		end
	end
	local skelEn = en and onSc and opt.skel
	local skel = self.draw.skel
	local gskel = self.draw.gskel

	if skelEn and self.skpts then
		local pts = self.skpts
		local cloneInfo = itf._clones[self.plr]
		local viewport = cloneInfo and cloneInfo.viewport
		local w2sFunc = self.customW2s or w2sc
		
		local function drwln(ln, p1, p2)
			if p1 and p2 then
				local s1, v1 = w2sFunc(p1)
				local s2, v2 = w2sFunc(p2)
				if v1 and v2 then
					ln.From = s1
					ln.To = s2
					ln.Visible = true
					ln.Color = parseC(self, opt.skelCol[1])
					ln.Transparency = opt.skelCol[2]
					return true
				end
			end
			ln.Visible = false
			return false
		end
		drwln(skel.hd, pts.hd, pts.ur)
		drwln(skel.nt, pts.ur, pts.lr)
		drwln(skel.ls, pts.ur, pts.lua)
		drwln(skel.rs, pts.ur, pts.rua)
		drwln(skel.la, pts.lua, pts.lfa)
		drwln(skel.ra, pts.rua, pts.rfa)
		drwln(skel.ll, pts.lr, pts.lul)
		drwln(skel.rl, pts.lr, pts.rul)
		drwln(skel.bh, pts.lul, pts.lll)
		if not self.draw.skel.rlb then
			self.draw.skel.rlb = self:_c("Line", { Thickness = 2, Visible = false })
			self.draw.gskel.rlb = self:_c("Line", { Thickness = 3, Visible = false })
			table.insert(self.bin, self.draw.skel.rlb)
			table.insert(self.bin, self.draw.gskel.rlb)
		end
		
		drwln(skel.rlb, pts.rul, pts.rll)
		
		if opt.gskel then
			drwln(gskel.hd, pts.hd, pts.ur)
			drwln(gskel.nt, pts.ur, pts.lr)
			drwln(gskel.ls, pts.ur, pts.lua)
			drwln(gskel.rs, pts.ur, pts.rua)
			drwln(gskel.la, pts.lua, pts.lfa)
			drwln(gskel.ra, pts.rua, pts.rfa)
			drwln(gskel.ll, pts.lr, pts.lul)
			drwln(gskel.rl, pts.lr, pts.rul)
			drwln(gskel.bh, pts.lul, pts.lll)
			drwln(gskel.rlb, pts.rul, pts.rll)
			
			for _, ln in pairs(gskel) do
				if ln.Visible then
					ln.Color = parseC(self, opt.gskelCol[1], true)
					ln.Transparency = opt.gskelCol[2]
				end
			end
		end
	else
		for _, ln in pairs(skel) do ln.Visible = false end
		for _, ln in pairs(gskel) do ln.Visible = false end
	end
end
function Esp:updateSkel()
    if not self.char or not self.onSc then return end
    
    local bodyPartsChecklist = {
        "Head", "UpperTorso", "LowerTorso",
        "LeftUpperArm", "RightUpperArm", 
