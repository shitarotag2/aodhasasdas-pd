local Cham = {}
Cham.__index = Cham

function Cham.new(p, itf)
	local self = setmetatable({}, Cham)
	self.plr = assert(p, "No player")
	self.itf = assert(itf, "No interface")
	self:init()
	return self
end

function Cham:init()
	self.hl = Instance.new("Highlight", gui)
	self.hl.Enabled = false
	self.hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	self.matCache = {}
	self.acc = 0
	self.cacheChar = nil
	self.charConns = {}
end

function Cham:Dest()
	for _, conn in pairs(self.charConns) do
		pcall(function() conn:Disconnect() end)
	end
	cl(self.charConns)
	if self.hl then self.hl:Destroy() end
	self:ClearOcclusion()
	self:RestoreMaterials()
	cl(self)
end

function Cham:SaveMaterials(char)
	if not char then return end
	for _, part in pairs(char:GetDescendants()) do
		if isCP(part) and not self.matCache[part] then
			self.matCache[part] = { part.Material, part.Color }
		end
	end
end

function Cham:RestoreMaterials()
	for part, data in pairs(self.matCache) do
		if part and part.Parent then
			part.Material = data[1]
			part.Color = data[2]
		end
	end
	cl(self.matCache)
end

function Cham:ApplyMaterials(char, col)
	if not char then return end
	self:SaveMaterials(char)
	for _, part in pairs(char:GetDescendants()) do
		if isCP(part) then
			part.Material = Enum.Material.ForceField
			part.Color = col
		end
	end
end

function Cham:ClearOcclusion()
	if self.occModel then self.occModel:Destroy() self.occModel = nil end
	if self.losHl then self.losHl:Destroy() self.losHl = nil end
	if self.occHl then self.occHl:Destroy() self.occHl = nil end
	self.occChar = nil
end

function Cham:ApplyOcclusion(char, visCol, visT, occCol, occT)
	if not char then return end
	if self.occChar ~= char or not self.occModel or not self.occModel.Parent then
		self:ClearOcclusion()
		self.occChar = char
		local model = Instance.new("Model")
		model.Name = "ChamsChr"
		for _, child in pairs(char:GetDescendants()) do
			if isCP(child) then
				local cloned = child:Clone()
				cloned:ClearAllChildren()
				cloned.CanCollide = false
				cloned.CanQuery = false
				cloned.CanTouch = false
				cloned.Massless = true
				cloned.CastShadow = false
				if cloned:IsA("MeshPart") then cloned.TextureID = "" end
				cloned.Size = cloned.Size * 0.99
				cloned.Parent = model
				local weld = Instance.new("WeldConstraint")
				weld.Part0 = cloned
				weld.Part1 = child
				weld.Parent = cloned
			end
		end
		model.Parent = ws
		self.occModel = model

		local los = Instance.new("Highlight")
		los.DepthMode = Enum.HighlightDepthMode.Occluded
		los.OutlineTransparency = 1
		los.Adornee = char
		los.Parent = gui
		self.losHl = los

		local occ = Instance.new("Highlight")
		occ.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		occ.OutlineTransparency = 1
		occ.Adornee = model
		occ.Parent = gui
		self.occHl = occ
	end
	self.losHl.FillColor = visCol
	self.losHl.FillTransparency = visT
	self.occHl.FillColor = occCol
	self.occHl.FillTransparency = occT
end

function Cham:Upd(dt)
	local hl = self.hl
	local itf = self.itf
	if not self.plr or not self.plr.Parent then
		hl.Enabled = false
		self:ClearOcclusion()
		self:RestoreMaterials()
		return
	end

	local char = itf.getChar(self.plr)
	
	if char ~= self.cacheChar then
		self:ClearOcclusion()
		self:RestoreMaterials()
		self.cacheChar = char
		
		for _, conn in pairs(self.charConns) do
			pcall(function() conn:Disconnect() end)
		end
		cl(self.charConns)
		
		if char then
			local function invalidate()
				self:ClearOcclusion()
				self:RestoreMaterials()
			end
			
			self.charConns[1] = char.ChildAdded:Connect(invalidate)
			self.charConns[2] = char.ChildRemoved:Connect(invalidate)
			
			local hum = char:FindFirstChildOfClass("Humanoid")
			if hum then
				self.charConns[3] = hum.Died:Connect(invalidate)
			end
		end
	end
	
	local opt = itf.tSet[itf.isFr(self.plr) and "fr" or "en"]
	local hasUserId = pcall(function()
		return self.plr.UserId ~= nil
	end)
	local en
	if self.plr == lp and not self.itf.allowlocal then
		en = false
	else
		en = opt.en and char and hasUserId and not
			(#itf.wlist > 0 and not fd(itf.wlist, self.plr.UserId))
	end

	local cloneInfo = itf._clones[self.plr]
	local rk = roleKey(self)

	hl.Enabled = (en and opt.chams and not cloneInfo) and true or false
	if hl.Enabled then
		local fcol = opt["chamsFCol" .. rk]
		local ocol = opt["chamsOCol" .. rk]
		hl.Adornee = char
		hl.FillColor = parseC(self, fcol[1])
		hl.FillTransparency = fcol[2]
		hl.OutlineColor = parseC(self, ocol[1], true)
		hl.OutlineTransparency = ocol[2]
	end

	self.acc = (self.acc or 0) + (dt or 0)
	if self.acc < 0.15 then return end
	self.acc = 0

	if en and opt.matChams and char and self.plr ~= lp then
		if opt.matChamsType == "Flat" then
			self:RestoreMaterials()
			self:ApplyOcclusion(char,
				parseC(self, opt["matChamsVisCol" .. rk][1]), opt["matChamsVisCol" .. rk][2],
				parseC(self, opt["matChamsOccCol" .. rk][1]), opt["matChamsOccCol" .. rk][2])
		else
			self:ClearOcclusion()
			self:ApplyMaterials(char, parseC(self, opt["matChamsCol" .. rk]))
		end
	else
		self:ClearOcclusion()
		self:RestoreMaterials()
	end
end
local Inst = {}
Inst.__index = Inst

function Inst.new(i, opt)
	local self = setmetatable({}, Inst)
	self.inst = assert(i, "No instance")
	self.opt = assert(opt, "No options")
	self:init()
	return self
end

function Inst:init()
	local opt = self.opt
	opt.en = opt.en == nil and true or opt.en
	opt.txt = opt.txt or "{name}"
	opt.txtCol = opt.txtCol or { Color3.new(1,1,1), 1 }
	opt.txtOut = opt.txtOut == nil and true or opt.txtOut
	opt.txtOCol = opt.txtOCol or Color3.new()
	opt.txtSz = opt.txtSz or 13
	opt.txtFnt = opt.txtFnt or 2
	opt.limDis = opt.limDis or false
	opt.maxDis = opt.maxDis or 150
	opt.txtGrd = opt.txtGrd or false
	opt.txtGrdCol = opt.txtGrdCol or { Color3.new(1,1,1), Color3.new(1,0,0) }

	self.txt = Drawing.new("Text")
	self.txt.Center = true
	self.gtxt = {}
	self.ph = math.random()
end

function Inst:drawGrad(text, cx, cy, sz, fnt, out, oc, tr, c1, c2, off)
	local pool = self.gtxt
	local n = #text
	local widths = {}
	local total = 0
	for i = 1, n do
		local o = pool[i]
		if not o then
			o = Drawing.new("Text")
			o.Center = false
			pool[i] = o
		end
		o.Size = sz
		o.Font = fnt
		o.Text = text:sub(i, i)
		widths[i] = o.TextBounds.X
		total = total + widths[i]
	end
	for i = n + 1, #pool do pool[i].Visible = false end
	local x = cx - total*0.5
	for i = 1, n do
		local o = pool[i]
		o.Color = gradS(c1, c2, n > 1 and (i-1)/(n-1) or 0, off)
		o.Transparency = tr
		o.Outline = out
		o.OutlineColor = oc
		o.Position = Vector2.new(x, cy)
		o.Visible = true
		x = x + widths[i]
	end
end

function Inst:hideGrad()
	for i = 1, #self.gtxt do self.gtxt[i].Visible = false end
end

function Inst:Dest()
	self.txt:Remove()
	for i = 1, #self.gtxt do pcall(function() self.gtxt[i]:Remove() end) end
	self.gtxt = {}
end

function Inst:Ren()
	local inst = self.inst
	if not inst or not inst.Parent then
		return self:Dest()
	end

	local txt = self.txt
	local opt = self.opt
	if not opt.en then
		txt.Visible = false
		self:hideGrad()
		return
	end

	local w = gp(inst).Position
	local pos, vis, dep = w2sc(w)
	if opt.limDis and dep > opt.maxDis then
		vis = false
	end

	if not vis then
		txt.Visible = false
		self:hideGrad()
		return
	end

	local s = opt.txt
		:gsub("{name}", inst.Name)
		:gsub("{distance}", rd(dep))
		:gsub("{position}", tostring(w))

	if opt.txtGrd then
		txt.Visible = false
		self:drawGrad(s, pos.X, pos.Y, opt.txtSz, opt.txtFnt, opt.txtOut, opt.txtOCol, opt.txtCol[2], opt.txtGrdCol[1], opt.txtGrdCol[2], self.ph)
	else
		self:hideGrad()
		txt.Visible = true
		txt.Position = pos
		txt.Color = opt.txtCol[1]
		txt.Transparency = opt.txtCol[2]
		txt.Outline = opt.txtOut
		txt.OutlineColor = opt.txtOCol
		txt.Size = opt.txtSz
		txt.Font = opt.txtFnt
		txt.Text = s
	end
end

